)
(rule
    ((= ?kind (FusionEnd ?shape ?strides (TF32)))
     (= ?__cuda_elems (n_elements ?shape)))
    ((cuda_output_bytes ?kind (MCeilDiv (MMul ?__cuda_elems (MNum 19)) (MNum 8))))
