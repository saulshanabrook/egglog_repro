(rule ((= ?__rw (MAdd ?a (MMul (MNum ?n) ?a)))) ((union ?__rw (MMul (MNum (+ ?n 1)) ?a)) (subsume (MAdd ?a (MMul (MNum ?n) ?a)))) :ruleset expr :name "combine-like-2")
