)
(rule
    ((= ?kind (KernelAdd ?shape ?a_strides ?b_strides ?out_strides (F16)))
     (= ?__cuda_elems (n_elements ?shape)))
    ((cuda_output_bytes ?kind (MCeilDiv (MMul ?__cuda_elems (MNum 16)) (MNum 8))))
