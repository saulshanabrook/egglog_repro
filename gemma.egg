(rule (
                        (= ?bi (Op (KernelAdd ?shape ?ai_s ?bi_s ?oi_s ?dt)
                                    (ICons ?a (ICons ?b (INil)))))
                        (= ?bo (Op (KernelAdd ?shape ?co_s ?oi_s ?oo_s ?dt)
                                    (ICons ?c (ICons ?bi (INil)))))
