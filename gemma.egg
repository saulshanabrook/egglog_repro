(rule
    ((= ?kind (KernelBatchMatMul ?out_shape ?k_dim ?a_stride ?a_k_stride ?b_stride ?b_k_stride ?out_strides (F32)))
     (= ?__cuda_elems (n_elements ?out_shape)))
    ((cuda_output_bytes ?kind (MCeilDiv (MMul ?__cuda_elems (MNum 32)) (MNum 8))))
