(rule ((= ?__rw (MAdd (MAdd ?a (MVar ?v)) (MVar ?v)))) ((union ?__rw (MAdd ?a (MMul (MNum 2) (MVar ?v)))) (subsume (MAdd (MAdd ?a (MVar ?v)) (MVar ?v)))) :ruleset expr :name "combine-var-1")
