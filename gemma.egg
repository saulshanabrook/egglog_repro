(rule ((= ?__rw (MAdd (MAdd (MMul (MNum ?n) ?a) ?b) ?a))) ((union ?__rw (MAdd (MMul (MNum (+ ?n 1)) ?a) ?b)) (subsume (MAdd (MAdd (MMul (MNum ?n) ?a) ?b) ?a))) :ruleset expr :name "accum-1")
