                        (let ?fs_b (Op (FusionStart ?shape ?bi_s ?dt) (ICons ?b (INil))))
                        (let ?fs_c (Op (FusionStart ?shape ?co_s ?dt) (ICons ?c (INil))))
                        (let ?fbi (Op (FusedAdd ?shape ?ai_s ?bi_s ?oi_s ?dt)
