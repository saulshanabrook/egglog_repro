(rule ((= ?e (ENil))) ((set (n_elements ?e) (MNum 1))) :ruleset expr)
(rule ((= ?e (ECons ?dim ?other)) (= ?other_elems (n_elements ?other))) ((set (n_elements ?e) (MMul ?dim ?other_elems))) :ruleset expr)
