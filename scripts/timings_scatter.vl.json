{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Plots per-benchmark timing means and precomputed 95% CIs from results/timing_mean_ci.csv. Timeout or failed rows are treated as right-censored lower-bound observations.",
  "title": {
    "text": "egglog #872 timing means by model file",
    "subtitle": "Lines connect point estimates; vertical bars are 95% CIs"
  },
  "padding": {
    "left": 5,
    "top": 5,
    "right": 5,
    "bottom": 35
  },
  "data": {
    "url": "../results/timing_mean_ci.csv",
    "format": {
      "type": "csv",
      "parse": {
        "experiment_order": "number",
        "variant_order": "number",
        "parallel_order": "number",
        "n": "number",
        "n_timeout": "number",
        "mean_ms": "number",
        "ci_lower_ms": "number",
        "ci_upper_ms_plot": "number",
        "ci_upper_is_infinite": "boolean"
      }
    }
  },
  "transform": [
    {
      "calculate": "datum.mean_ms >= 1000 ? format(datum.mean_ms / 1000, '.2~f') + 's' : format(datum.mean_ms, '.0f') + 'ms'",
      "as": "mean_time_label"
    },
    {
      "calculate": "datum.ci_upper_is_infinite ? '≥' + datum.mean_time_label : datum.mean_time_label",
      "as": "time_label"
    }
  ],
  "facet": {
    "row": {
      "field": "parallel",
      "type": "nominal",
      "sort": {
        "field": "parallel_order",
        "op": "min",
        "order": "ascending"
      },
      "title": "Mode",
      "header": {
        "labelFontSize": 13,
        "labelFontWeight": "bold",
        "labelAngle": 0,
        "labelAlign": "left"
      }
    }
  },
  "spec": {
    "width": 760,
    "height": 300,
    "layer": [
      {
        "transform": [
          {
            "filter": "datum.experiment_order === 0"
          }
        ],
        "mark": {
          "type": "rule",
          "color": "#ddd",
          "strokeWidth": 1
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative"
          },
          "y": {
            "value": 0
          },
          "y2": {
            "value": 300
          }
        }
      },
      {
        "mark": {
          "type": "line",
          "strokeWidth": 2.25,
          "opacity": 0.68
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "mean_ms",
            "type": "quantitative",
            "scale": {
              "type": "log",
              "base": 10,
              "nice": false
            },
            "axis": {
              "title": "Time (ms, log scale)",
              "values": [
                1000,
                2000,
                3000,
                10000,
                30000,
                60000,
                100000,
                150000
              ],
              "labelExpr": "datum.value >= 1000 ? format(datum.value / 1000, '~g') + 's' : format(datum.value, '~g') + 'ms'"
            }
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            },
            "legend": {
              "title": "Benchmark",
              "orient": "top"
            }
          },
          "detail": {
            "field": "experiment"
          },
          "order": {
            "field": "variant_order",
            "type": "quantitative"
          }
        }
      },
      {
        "mark": {
          "type": "rule",
          "strokeWidth": 3,
          "opacity": 0.72
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "ci_lower_ms",
            "type": "quantitative"
          },
          "y2": {
            "field": "ci_upper_ms_plot"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "mark": {
          "type": "point",
          "filled": true,
          "size": 28,
          "opacity": 0.9
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "mean_ms",
            "type": "quantitative"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "mark": {
          "type": "text",
          "align": {
            "expr": "datum.experiment_order < 3 ? 'right' : 'left'"
          },
          "baseline": "middle",
          "dx": {
            "expr": "datum.experiment_order < 3 ? -7 : 7"
          },
          "dy": {
            "expr": "((datum.experiment_order % 3) - 1) * 4"
          },
          "fontSize": 10
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "mean_ms",
            "type": "quantitative"
          },
          "text": {
            "field": "time_label",
            "type": "nominal"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "transform": [
          {
            "filter": "datum.experiment_order === 0"
          }
        ],
        "mark": {
          "type": "text",
          "fontSize": 12,
          "baseline": "top"
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative"
          },
          "y": {
            "value": 306
          },
          "text": {
            "field": "variant",
            "type": "nominal"
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "y": "shared",
      "color": "shared",
      "x": "shared"
    }
  },
  "config": {
    "axis": {
      "grid": true,
      "titleFontSize": 13,
      "labelFontSize": 12
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "view": {
      "stroke": null
    }
  }
}
