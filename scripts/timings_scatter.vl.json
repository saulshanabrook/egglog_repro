{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Plots per-benchmark timing means and Vega-Lite aggregate 95% CIs from results/timings_scatter.csv. Timeout or failed rows are included at their recorded per-run cap.",
  "title": {
    "text": "egglog #872 timing means by model file",
    "subtitle": "Vertical lines are 95% CIs of recorded run times; timeout/failed rows are included at the cap"
  },
  "padding": {
    "left": 5,
    "top": 5,
    "right": 5,
    "bottom": 35
  },
  "data": {
    "url": "../results/timings_scatter.csv",
    "format": {
      "type": "csv",
      "parse": {
        "run": "number",
        "time_ms": "number",
        "tuples": "number"
      }
    }
  },
  "transform": [
    {
      "window": [
        {
          "op": "row_number",
          "as": "source_row"
        }
      ]
    },
    {
      "joinaggregate": [
        {
          "op": "min",
          "field": "source_row",
          "as": "experiment_order"
        }
      ],
      "groupby": ["experiment"]
    },
    {
      "joinaggregate": [
        {
          "op": "min",
          "field": "source_row",
          "as": "variant_order"
        }
      ],
      "groupby": ["variant"]
    },
    {
      "calculate": "datum.parallel === 'parallel off' ? 'serial' : 'default Rayon'",
      "as": "parallel_label"
    },
    {
      "calculate": "datum.parallel === 'parallel off' ? 0 : 1",
      "as": "parallel_order"
    },
    {
      "calculate": "datum.status === 'complete' ? 0 : 1",
      "as": "timeout_flag"
    },
    {
      "aggregate": [
        {
          "op": "mean",
          "field": "time_ms",
          "as": "mean_time_ms"
        },
        {
          "op": "ci0",
          "field": "time_ms",
          "as": "ci_lower_ms"
        },
        {
          "op": "ci1",
          "field": "time_ms",
          "as": "ci_upper_ms"
        },
        {
          "op": "min",
          "field": "experiment_order",
          "as": "experiment_order"
        },
        {
          "op": "min",
          "field": "variant_order",
          "as": "variant_order"
        },
        {
          "op": "min",
          "field": "parallel_order",
          "as": "parallel_order"
        },
        {
          "op": "count",
          "as": "n"
        },
        {
          "op": "max",
          "field": "timeout_flag",
          "as": "any_timeout"
        }
      ],
      "groupby": ["experiment", "variant", "parallel_label"]
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "experiment_order",
          "as": "max_experiment_order"
        }
      ]
    },
    {
      "calculate": "datum.experiment_order - datum.max_experiment_order / 2",
      "as": "experiment_offset"
    },
    {
      "calculate": "datum.mean_time_ms >= 1000 ? format(datum.mean_time_ms / 1000, '.2~f') + 's' : format(datum.mean_time_ms, '.0f') + 'ms'",
      "as": "mean_time_label"
    },
    {
      "calculate": "datum.any_timeout ? '>' + datum.mean_time_label : datum.mean_time_label",
      "as": "time_label"
    }
  ],
  "facet": {
    "column": {
      "field": "variant",
      "type": "nominal",
      "sort": {
        "field": "variant_order",
        "op": "min",
        "order": "ascending"
      },
      "title": "Commit",
      "header": {
        "labelFontSize": 13,
        "labelFontWeight": "bold"
      }
    }
  },
  "spec": {
    "width": 240,
    "height": 520,
    "layer": [
      {
        "mark": {
          "type": "rule",
          "strokeWidth": 3,
          "opacity": 0.72
        },
        "encoding": {
          "x": {
            "field": "parallel_label",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            },
            "axis": {
              "title": null,
              "labelAngle": 0
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "ci_lower_ms",
            "type": "quantitative",
            "scale": {
              "type": "log",
              "base": 10,
              "nice": false
            },
            "axis": {
              "title": "Time (ms, log scale)",
              "values": [1000, 2000, 3000, 10000, 30000, 60000, 100000, 150000],
              "labelExpr": "datum.value >= 1000 ? format(datum.value / 1000, '~g') + 's' : format(datum.value, '~g') + 'ms'"
            }
          },
          "y2": {
            "field": "ci_upper_ms"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            },
            "legend": {
              "title": "Benchmark",
              "orient": "top"
            }
          }
        }
      },
      {
        "mark": {
          "type": "text",
          "align": "left",
          "baseline": "middle",
          "dx": 7,
          "fontSize": 11
        },
        "encoding": {
          "x": {
            "field": "parallel_label",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "mean_time_ms",
            "type": "quantitative"
          },
          "text": {
            "field": "time_label",
            "type": "nominal"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "y": "shared",
      "color": "shared"
    }
  },
  "config": {
    "axis": {
      "grid": true,
      "titleFontSize": 13,
      "labelFontSize": 12
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "view": {
      "stroke": null
    }
  }
}
