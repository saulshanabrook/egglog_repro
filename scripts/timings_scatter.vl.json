{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Plots per-benchmark timing means and precomputed 95% CIs from results/timing_mean_ci.csv. Timeout or failed rows are treated as right-censored lower-bound observations.",
  "title": {
    "text": "egglog #872 timing means by model file",
    "subtitle": "Vertical lines are 95% CIs; upward triangles are lower-bounded right-censored intervals"
  },
  "padding": {
    "left": 5,
    "top": 5,
    "right": 5,
    "bottom": 35
  },
  "data": {
    "url": "../results/timing_mean_ci.csv",
    "format": {
      "type": "csv",
      "parse": {
        "experiment_order": "number",
        "variant_order": "number",
        "parallel_order": "number",
        "n": "number",
        "n_timeout": "number",
        "mean_ms": "number",
        "ci_lower_ms": "number",
        "ci_upper_ms_plot": "number",
        "ci_upper_is_infinite": "boolean"
      }
    }
  },
  "transform": [
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "experiment_order",
          "as": "max_experiment_order"
        }
      ]
    },
    {
      "calculate": "datum.experiment_order - datum.max_experiment_order / 2",
      "as": "experiment_offset"
    },
    {
      "calculate": "datum.mean_ms >= 1000 ? format(datum.mean_ms / 1000, '.2~f') + 's' : format(datum.mean_ms, '.0f') + 'ms'",
      "as": "mean_time_label"
    },
    {
      "calculate": "datum.ci_upper_is_infinite ? '≥' + datum.mean_time_label : datum.mean_time_label",
      "as": "time_label"
    }
  ],
  "facet": {
    "column": {
      "field": "variant",
      "type": "nominal",
      "sort": {
        "field": "variant_order",
        "op": "min",
        "order": "ascending"
      },
      "title": "Commit",
      "header": {
        "labelFontSize": 13,
        "labelFontWeight": "bold"
      }
    }
  },
  "spec": {
    "width": 240,
    "height": 520,
    "layer": [
      {
        "mark": {
          "type": "rule",
          "strokeWidth": 3,
          "opacity": 0.72
        },
        "encoding": {
          "x": {
            "field": "parallel",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            },
            "axis": {
              "title": null,
              "labelAngle": 0
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "ci_lower_ms",
            "type": "quantitative",
            "scale": {
              "type": "log",
              "base": 10,
              "nice": false
            },
            "axis": {
              "title": "Time (ms, log scale)",
              "values": [1000, 2000, 3000, 10000, 30000, 60000, 100000, 150000],
              "labelExpr": "datum.value >= 1000 ? format(datum.value / 1000, '~g') + 's' : format(datum.value, '~g') + 'ms'"
            }
          },
          "y2": {
            "field": "ci_upper_ms_plot"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            },
            "legend": {
              "title": "Benchmark",
              "orient": "top"
            }
          }
        }
      },
      {
        "transform": [
          {
            "filter": "datum.ci_upper_is_infinite"
          }
        ],
        "mark": {
          "type": "point",
          "shape": "triangle-up",
          "filled": true,
          "size": 70,
          "opacity": 0.72
        },
        "encoding": {
          "x": {
            "field": "parallel",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "ci_upper_ms_plot",
            "type": "quantitative"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "mark": {
          "type": "text",
          "align": {
            "expr": "datum.experiment_offset < 0 ? 'right' : 'left'"
          },
          "baseline": "middle",
          "dx": {
            "expr": "datum.experiment_offset < 0 ? -7 : 7"
          },
          "dy": {
            "expr": "datum.ci_upper_is_infinite ? ((datum.experiment_order % 3) - 1) * 9 : 0"
          },
          "fontSize": 11
        },
        "encoding": {
          "x": {
            "field": "parallel",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "mean_ms",
            "type": "quantitative"
          },
          "text": {
            "field": "time_label",
            "type": "nominal"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "y": "shared",
      "color": "shared"
    }
  },
  "config": {
    "axis": {
      "grid": true,
      "titleFontSize": 13,
      "labelFontSize": 12
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "view": {
      "stroke": null
    }
  }
}
