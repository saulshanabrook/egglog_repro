{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Plots the ratio-of-execution-time-means percent changes and one-level Fieller-style 95% CIs precomputed by scripts/compute_timing_percent_change.mjs, following Kalibera and Jones, Quantifying Performance Changes with Effect Size Confidence Intervals.",
  "title": {
    "text": "egglog #872 percent change vs old serial baseline",
    "subtitle": "Vertical lines are 95% CIs; labels show ratio-of-means percent change"
  },
  "padding": {
    "left": 5,
    "top": 5,
    "right": 5,
    "bottom": 35
  },
  "data": {
    "url": "../results/timing_percent_change.csv",
    "format": {
      "type": "csv",
      "parse": {
        "experiment_order": "number",
        "variant_order": "number",
        "parallel_order": "number",
        "n_baseline": "number",
        "n": "number",
        "baseline_mean_ms": "number",
        "mean_ms": "number",
        "ratio_mean": "number",
        "percent_change": "number",
        "ci_lower_ratio": "number",
        "ci_upper_ratio": "number",
        "ci_lower_percent": "number",
        "ci_upper_percent": "number"
      }
    }
  },
  "transform": [
    {
      "calculate": "abs(datum.percent_change) >= 1000 ? format(datum.percent_change, '+.3s') + '%' : format(datum.percent_change, '+.0f') + '%'",
      "as": "percent_label"
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "experiment_order",
          "as": "max_experiment_order"
        }
      ]
    },
    {
      "calculate": "datum.experiment_order - datum.max_experiment_order / 2",
      "as": "experiment_offset"
    }
  ],
  "facet": {
    "column": {
      "field": "variant",
      "type": "nominal",
      "sort": {
        "field": "variant_order",
        "op": "min",
        "order": "ascending"
      },
      "title": "Commit",
      "header": {
        "labelFontSize": 13,
        "labelFontWeight": "bold"
      }
    }
  },
  "spec": {
    "width": 240,
    "height": 520,
    "layer": [
      {
        "mark": {
          "type": "rule",
          "strokeDash": [4, 4],
          "opacity": 0.35
        },
        "encoding": {
          "y": {
            "datum": 1,
            "type": "quantitative",
            "scale": {
              "type": "log",
              "base": 10,
              "nice": false
            },
            "axis": {
              "title": "% change vs old serial baseline (log ratio scale)",
              "values": [0.7, 0.8, 1, 2, 10, 100, 1000, 3000],
              "labelExpr": "datum.value === 1 ? '0%' : datum.value < 1 ? format((datum.value - 1) * 100, '.0f') + '%' : '+' + format((datum.value - 1) * 100, '.2s') + '%'"
            }
          }
        }
      },
      {
        "mark": {
          "type": "rule",
          "strokeWidth": 3,
          "opacity": 0.72
        },
        "encoding": {
          "x": {
            "field": "parallel",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            },
            "axis": {
              "title": null,
              "labelAngle": 0
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "ci_lower_ratio",
            "type": "quantitative"
          },
          "y2": {
            "field": "ci_upper_ratio"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            },
            "legend": {
              "title": "Benchmark",
              "orient": "top"
            }
          }
        }
      },
      {
        "mark": {
          "type": "text",
          "align": "left",
          "baseline": "middle",
          "dx": 7,
          "fontSize": 11
        },
        "encoding": {
          "x": {
            "field": "parallel",
            "type": "nominal",
            "sort": {
              "field": "parallel_order",
              "op": "min",
              "order": "ascending"
            }
          },
          "xOffset": {
            "field": "experiment_offset",
            "type": "quantitative",
            "scale": {
              "range": [-42, 42]
            }
          },
          "y": {
            "field": "ratio_mean",
            "type": "quantitative"
          },
          "text": {
            "field": "percent_label",
            "type": "nominal"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "y": "shared",
      "color": "shared"
    }
  },
  "config": {
    "axis": {
      "grid": true,
      "titleFontSize": 13,
      "labelFontSize": 12
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "view": {
      "stroke": null
    }
  }
}
