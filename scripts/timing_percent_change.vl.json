{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Plots ratio-of-execution-time-means percent changes and 95% CIs precomputed by scripts/compute_timing_percent_change.mjs, following Kalibera and Jones. Timeout rows are exact capped-runtime observations; if any run times out, the plotted interval uses the capped Fieller lower bound and an infinite upper bound for the true uncapped runtime ratio.",
  "title": {
    "text": "egglog #872 percent change vs old serial baseline",
    "subtitle": "Lines connect point estimates; vertical bars are 95% CIs"
  },
  "padding": {
    "left": 5,
    "top": 5,
    "right": 5,
    "bottom": 35
  },
  "data": {
    "url": "../results/timing_percent_change.csv",
    "format": {
      "type": "csv",
      "parse": {
        "experiment_order": "number",
        "variant_order": "number",
        "parallel_order": "number",
        "n_baseline": "number",
        "n": "number",
        "n_timeout": "number",
        "baseline_mean_ms": "number",
        "mean_ms": "number",
        "ratio_mean": "number",
        "percent_change": "number",
        "ci_lower_ratio": "number",
        "ci_lower_percent": "number",
        "ci_upper_ratio_plot": "number",
        "ci_upper_is_infinite": "boolean"
      }
    }
  },
  "transform": [
    {
      "calculate": "abs(datum.percent_change) >= 1000 ? format(datum.percent_change, '+.3s') + '%' : format(datum.percent_change, '+.0f') + '%'",
      "as": "base_percent_label"
    },
    {
      "calculate": "datum.ci_upper_is_infinite ? '≥' + datum.base_percent_label : datum.base_percent_label",
      "as": "percent_label"
    }
  ],
  "facet": {
    "row": {
      "field": "parallel",
      "type": "nominal",
      "sort": {
        "field": "parallel_order",
        "op": "min",
        "order": "ascending"
      },
      "title": "Mode",
      "header": {
        "labelFontSize": 13,
        "labelFontWeight": "bold",
        "labelAngle": 0,
        "labelAlign": "left"
      }
    }
  },
  "spec": {
    "width": 760,
    "height": 300,
    "layer": [
      {
        "transform": [
          {
            "filter": "datum.experiment_order === 0"
          }
        ],
        "mark": {
          "type": "rule",
          "color": "#ddd",
          "strokeWidth": 1
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative"
          },
          "y": {
            "value": 0
          },
          "y2": {
            "value": 300
          }
        }
      },
      {
        "mark": {
          "type": "rule",
          "strokeDash": [
            4,
            4
          ],
          "opacity": 0.35
        },
        "encoding": {
          "y": {
            "datum": 1,
            "type": "quantitative",
            "scale": {
              "type": "log",
              "base": 10,
              "nice": false
            },
            "axis": {
              "title": "% change vs old serial baseline (log ratio scale)",
              "values": [
                0.1,
                0.2,
                0.5,
                0.8,
                1,
                2,
                3
              ],
              "labelExpr": "datum.value === 1 ? '0%' : datum.value < 1 ? format((datum.value - 1) * 100, '.0f') + '%' : '+' + format((datum.value - 1) * 100, '.0f') + '%'"
            }
          }
        }
      },
      {
        "mark": {
          "type": "line",
          "strokeWidth": 2.25,
          "opacity": 0.68
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "ratio_mean",
            "type": "quantitative"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            },
            "legend": {
              "title": "Benchmark",
              "orient": "top"
            }
          },
          "detail": {
            "field": "experiment"
          },
          "order": {
            "field": "variant_order",
            "type": "quantitative"
          }
        }
      },
      {
        "mark": {
          "type": "rule",
          "strokeWidth": 3,
          "opacity": 0.72
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "ci_lower_ratio",
            "type": "quantitative"
          },
          "y2": {
            "field": "ci_upper_ratio_plot"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "mark": {
          "type": "point",
          "filled": true,
          "size": 28,
          "opacity": 0.9
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "ratio_mean",
            "type": "quantitative"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "mark": {
          "type": "text",
          "align": {
            "expr": "datum.experiment_order < 3 ? 'right' : 'left'"
          },
          "baseline": "middle",
          "dx": {
            "expr": "datum.experiment_order < 3 ? -7 : 7"
          },
          "dy": {
            "expr": "((datum.experiment_order % 3) - 1) * 4"
          },
          "fontSize": 10
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative",
            "scale": {
              "nice": false
            },
            "axis": {
              "title": "Commit",
              "labels": false,
              "ticks": false,
              "grid": false
            }
          },
          "y": {
            "field": "ratio_mean",
            "type": "quantitative"
          },
          "text": {
            "field": "percent_label",
            "type": "nominal"
          },
          "color": {
            "field": "experiment",
            "type": "nominal",
            "sort": {
              "field": "experiment_order",
              "op": "min",
              "order": "ascending"
            }
          }
        }
      },
      {
        "transform": [
          {
            "filter": "datum.experiment_order === 0"
          }
        ],
        "mark": {
          "type": "text",
          "fontSize": 12,
          "baseline": "top"
        },
        "encoding": {
          "x": {
            "field": "variant_order",
            "type": "quantitative"
          },
          "y": {
            "value": 306
          },
          "text": {
            "field": "variant",
            "type": "nominal"
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "y": "shared",
      "color": "shared",
      "x": "shared"
    }
  },
  "config": {
    "axis": {
      "grid": true,
      "titleFontSize": 13,
      "labelFontSize": 12
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "fontSize": 16,
      "subtitleFontSize": 12,
      "anchor": "start"
    },
    "view": {
      "stroke": null
    }
  }
}
