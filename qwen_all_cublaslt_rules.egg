            ?add_out_strides)
            (ICons ?bias (ICons ?matmul (INil)))))

        (= ?bias_add_strides (ECons (MNum 0) (ECons (MIter) (ENil))))
        (= ?matmul_add_strides ?add_out_strides)
        (= ?d_dtype (dtype ?bias))
    )
    (
        (let ?fused (Op (cublaslt
            ?m ?n ?k
            ?a_layout ?b_layout
            ?a_order ?b_order ?c_order "COL"
            ?lda ?ldb ?ldc ?ldd
