        (= ?not_mask_bool (Op (Cast ?size (Bool)) (ICons ?not_mask_f32 (INil))))
        (= ?not_mask (Op (Cast ?size (F32)) (ICons ?not_mask_bool (INil))))

        (= ?positive (Op (Mul
