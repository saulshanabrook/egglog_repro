(rule ((= ?__rw (MMod (MMod ?x (MNum ?y)) (MNum ?z))) (>= ?z ?y) (= 0 (% ?y ?z))) ((union ?__rw (MMod ?x (MNum ?y)))) :ruleset expr :name "mod-mod-larger")
