                        (let ?fbo (Op (FusedAdd ?shape ?co_s ?oi_s ?oo_s ?dt)
                                       (ICons ?fs_c (ICons ?fbi (INil)))))
                        (let ?fe (Op (FusionEnd ?shape ?oo_s ?dt) (ICons ?fbo (INil))))
